if(NOT EXISTS "@CMAKE_BINARY_DIR@/install_manifest.txt")
  message(FATAL_ERROR "install_manifest.txt is missing; run install before uninstall")
endif()

file(STRINGS "@CMAKE_BINARY_DIR@/install_manifest.txt" installed_files)
list(REVERSE installed_files)
foreach(installed_file IN LISTS installed_files)
  if(EXISTS "${installed_file}" OR IS_SYMLINK "${installed_file}")
    file(REMOVE "${installed_file}")
  endif()
endforeach()
